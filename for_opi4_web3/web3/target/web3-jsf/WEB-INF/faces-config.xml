<?xml version="1.0" encoding="UTF-8"?>
<faces-config xmlns="http://xmlns.jcp.org/xml/ns/javaee"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
              http://xmlns.jcp.org/xml/ns/javaee/web-facesconfig_2_3.xsd"
              version="2.3">

    <application>
        <locale-config>
            <default-locale>ru</default-locale>
        </locale-config>
    </application>

    <managed-bean>
        <managed-bean-name>resultHistoryBean</managed-bean-name>
        <managed-bean-class>ru.ifmo.web.beans.ResultHistoryBean</managed-bean-class>
        <managed-bean-scope>session</managed-bean-scope>
    </managed-bean>

    <managed-bean>
        <managed-bean-name>pointBean</managed-bean-name>
        <managed-bean-class>ru.ifmo.web.beans.PointBean</managed-bean-class>
        <managed-bean-scope>view</managed-bean-scope>
        <managed-property>
            <property-name>resultHistoryBean</property-name>
            <value>#{resultHistoryBean}</value>
        </managed-property>
    </managed-bean>

    <managed-bean>
        <managed-bean-name>clockBean</managed-bean-name>
        <managed-bean-class>ru.ifmo.web.beans.ClockBean</managed-bean-class>
        <managed-bean-scope>view</managed-bean-scope>
    </managed-bean>

</faces-config>
